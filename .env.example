OPENAI_API_KEY=sk-your-key-here

# Models
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Paths (relative to project root; Docker overrides these)
KNOWLEDGE_BASE_PATH=./knowledge-base
CHROMA_PATH=./data/chroma
CHROMA_COLLECTION=rag_kb

# Retrieval (threshold calibrated on eval/gold.jsonl score distributions)
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.45

# Semantic chunking (percentile breakpoint; higher = fewer, larger chunks)
SEMANTIC_BREAKPOINT_THRESHOLD=95
SEMANTIC_BUFFER_SIZE=1

# Ingest scale knobs
INGEST_EMBED_BATCH_SIZE=64
INGEST_MAX_WORKERS=2

# Visualization
VIZ_SAMPLE_SIZE=5000
VIZ_N_CLUSTERS=8
VIZ_CLUSTER_METHOD=kmeans

# Gradio
GRADIO_SERVER_NAME=0.0.0.0
GRADIO_SERVER_PORT=7860
